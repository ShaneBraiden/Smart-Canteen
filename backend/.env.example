# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=smart_canteen

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=True
APP_NAME=Smart Canteen System

# PaddleOCR Settings
# Set to True if you have a CUDA-compatible GPU
OCR_USE_GPU=False
# Default language: en (English)
# Other options: devanagari (Hindi), ta (Tamil), te (Telugu), etc.
OCR_LANG=en
